# Supabase project settings
# Get these values from your Supabase project dashboard.
# The app still uses mockData + localStorage by default.
# If these values are empty, frontend pages should continue to run without errors.
# Do not put real keys directly in source code.
# Do not put real keys in .env.example.
# Put real keys in .env.local, and do not commit .env.local to git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
