# Supabase project settings
# Get these values from your Supabase project dashboard.
# The app still uses mockData + localStorage by default.
# If these values are empty, frontend pages should continue to run without errors.
# Do not put real keys directly in source code.
# Do not put real keys in .env.example.
# Put real keys in .env.local, and do not commit .env.local to git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only AI provider settings.
# Do not add NEXT_PUBLIC_ to these keys.
# Keep real values in .env.local or deployment environment variables only.
AI_PROVIDER=mock

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=30000
DEEPSEEK_MAX_RETRIES=1
DEEPSEEK_MAX_TOKENS=3000
ENABLE_AI_DEV_TOOLS=false

OPENAI_API_KEY=
OPENAI_MODEL=

QWEN_API_KEY=
QWEN_MODEL=

# Server-only speech recognition settings for public Xiaohongshu videos.
ASR_PROVIDER=volcengine
ASR_FALLBACK_PROVIDER=aliyun_qwen
VOLC_ASR_API_KEY=
VOLC_ASR_APP_ID=
ALIBABA_ASR_API_KEY=
ALIBABA_ASR_BASE_URL=
ALIBABA_ASR_MODEL=qwen3-asr-flash

# Compatible aliases used by an earlier Aliyun console setup. Configure one
# naming pair only; ALIBABA_ASR_* takes precedence when both are present.
ALIYUN_MAAS_API_KEY=
ALIYUN_MAAS_ENDPOINT=

# Legacy Volcengine header mode. VOLC_ASR_API_KEY is preferred.
VOLC_ACCESS_KEY=

# Optional runtime overrides. Deployment builds normally install both tools.
YT_DLP_PATH=
FFMPEG_PATH=
